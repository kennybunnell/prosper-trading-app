{
  "query": "\nSELECT \n  underlying_symbol,\n  COUNT(*) as trade_count,\n  SUM(CASE WHEN action IN ('Sell to Open','Sell to Close') THEN CAST(net_value AS DECIMAL(12,2)) ELSE -CAST(net_value AS DECIMAL(12,2)) END) as net_pnl\nFROM cached_transactions\nWHERE transaction_type = 'Trade'\n  AND underlying_symbol IS NOT NULL\n  AND underlying_symbol != ''\n  AND net_value IS NOT NULL\nGROUP BY underlying_symbol\nORDER BY net_pnl DESC\nLIMIT 20;\n",
